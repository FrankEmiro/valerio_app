# ─── Brand da scrapare ──────────────────────────────────────────
# Slug del brand come appare nell'URL partseurope.eu
# Es: https://www.partseurope.eu/it/brands/saddlemen-1 → saddlemen-1
BRAND=saddlemen-1

# Numero massimo di pagine da esplorare (48 prodotti/pagina)
# Saddlemen ha ~1579 prodotti → ~33 pagine
MAX_PAGES=50

# ─── Schedulazione ──────────────────────────────────────────────
# Espressione cron (timezone: Europe/Rome)
# Ogni lunedì alle 8:00 (default)
CRON_SCHEDULE=0 8 * * 1
# Ogni giorno alle 6:00:
# CRON_SCHEDULE=0 6 * * *
# Ogni domenica a mezzanotte:
# CRON_SCHEDULE=0 0 * * 0
# Ogni ora (test):
# CRON_SCHEDULE=0 * * * *

# Esegui subito all'avvio del container (utile per il primo deploy)
RUN_ON_START=true

# ─── Email ───────────────────────────────────────────────────────
# Email del cliente che riceverà il file Excel
RECIPIENT_EMAIL=cliente@example.com

# Il tuo account Gmail mittente
GMAIL_USER=tua@gmail.com

# App Password Gmail (NON la password normale!)
# Come ottenerla:
#   1. Vai su myaccount.google.com → Sicurezza → Verifica in due passaggi (attivala)
#   2. Vai su myaccount.google.com/apppasswords
#   3. Seleziona "Posta" e il dispositivo, clicca "Genera"
#   4. Copia le 16 cifre (es: abcd efgh ijkl mnop) → incollale qui SENZA spazi
GMAIL_APP_PASSWORD=abcdefghijklmnop

# ─── Cookie partseurope.eu (opzionale) ──────────────────────────
# Solo se il sito inizia a bloccare le richieste anonime
# Come ottenerlo: apri partseurope.eu nel browser → F12 → Network →
# copia l'header "Cookie" da una qualsiasi richiesta
# COOKIE=maxPerPage=24; PHPSESSID=xxx; ...
